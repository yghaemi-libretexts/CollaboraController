# Server Configuration
PORT=3000

# Kubernetes Configuration
COLLABORA_SERVICE=collabora
COLLABORA_NAMESPACE=default

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
# REDIS_PASSWORD=

# AWS credentials (for EKS get-token and other AWS API calls)
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1


# Optional API auth: when set, proxy requests must send matching key/secret
# API_KEY=
# API_SECRET=

# Logging
LOG_LEVEL=info


# EKS
EKS_CLUSTER_NAME=cluster-name

