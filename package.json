{
  "name": "collabora-controller",
  "version": "1.0.0",
  "description": "Kubernetes load balancer controller for Collabora Online with WOPI document affinity",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "build:vite": "vite build",
    "start": "node dist/server.js",
    "dev": "tsx watch server.ts",
    "dev:vite": "vite",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "prepare": "husky"
  },
  "keywords": [
    "collabora",
    "kubernetes",
    "load-balancer",
    "wopi",
    "redis"
  ],
  "author": "LibreTexts",
  "license": "MIT",
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "express": "^4.18.2",
    "http-proxy-middleware": "^2.0.6",
    "redis": "^4.6.10",
    "winston": "^3.11.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.11",
    "@types/node": "^20.10.6",
    "@types/supertest": "^2.0.16",
    "husky": "^9.1.7",
    "jest": "^30.2.0",
    "supertest": "^6.3.3",
    "ts-jest": "^29.4.6",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vite": "^7.3.1"
  }
}
